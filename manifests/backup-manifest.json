    "SystemManager": {
      "description": "Backup del System Manager (Production Pro)",
      "destination": "S:\\BACKUP",
      "destinationDrive": "S",
      "requiredTools": [
        {
          "name": "hpdfe.bat",
          "pathEnvVar": "MOBIUS_HOME",
          "relativePath": "hpdfe.bat",
          "notes": "TODO: portar lógica interna a PowerShell nativo cuando esté disponible el contenido del archivo."
        },
        {
          "name": "backup.bat",
          "pathEnvVar": "MOBIUS_HOME",
          "relativePath": "tools\\backuprestore\\backup.bat",
          "notes": "TODO: portar lógica interna a PowerShell nativo cuando esté disponible el contenido del archivo."
        },
        {
          "name": "update_TrustedHosts.bat",
          "pathEnvVar": "MOBIUS_HOME",
          "relativePath": "tools\\database\\utils\\update_TrustedHosts.bat",
